# Traefik / Domain
WEB_DOMAIN=web.deinedomain.de
PWA_DOMAIN=pwa.deinedomain.de
LETSENCRYPT_EMAIL=deine@email.de

# DNS-Provider, z.B. cloudflare
DNS_CHALLENGE_PROVIDER=cloudflare
CF_DNS_API_TOKEN=your-cloudflare-api-token-here

# Backend – CORS
CORS_ORIGINS=https://web.deinedomain.de,https://pwa.deinedomain.de,http://localhost:3000,http://localhost:3001

# Backend-Konfiguration
SECRET_KEY=your_secret_key_here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
APLANO_API_KEY=your-aplano-api-key-here
# Optional: ausführliche INFEASIBLE-Diagnostik in API-Antwort/Logs
AUTO_PLAN_VERBOSE_INFEASIBLE=false

# Scheduler
AUTO_IMPORT_ENABLED=true
AUTO_IMPORT_TIMES=08:00,12:30,16:00

# Pfade für Excel-Import / Export
EXCEL_IMPORT_PATH=/path/to/excel_import
EXPORT_PALLIDOC_PATH=/path/to/Export_PalliDoc

# Feiertage (NRW, feiertage-api.de)
# HOLIDAY_API_BASE_URL=https://feiertage-api.de/api/
HOLIDAY_STATE=NW